# Core server
PORT=3000
PUBLIC_BASE_URL=https://your-hostname.example.com

# Entra OAuth / MCP registration
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
CHATGPT_CLIENT_ID=00000000-0000-0000-0000-000000000000
MCP_SERVICE_APP_ID=00000000-0000-0000-0000-000000000000
MCP_SERVICE_APP_CLIENT_SECRET=replace-with-secret-value
MCP_SCOPE=api://00000000-0000-0000-0000-000000000000/mcp.access

# Dataverse OBO target
DATAVERSE_URL=https://your-org.crm.dynamics.com
# DATAVERSE_SCOPE=https://your-org.crm.dynamics.com/user_impersonation
# DATAVERSE_API_VERSION=v9.2

# Runtime behavior
MCP_REQUIRE_AUTH=1
# MCP_STATELESS=1
# ENABLE_CATS_API=0
# REQUIRE_DB_ON_STARTUP=0

# CORS / host controls
# CORS_ALLOWED_ORIGINS=*
# CORS_ALLOW_CREDENTIALS=0
# ALLOWED_ORIGINS=*
# ALLOWED_HOSTS=your-hostname.example.com
